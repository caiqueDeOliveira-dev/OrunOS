# Orun OS — Environment Variables
# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA commit o arquivo .env no repositório.

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Sync interval in milliseconds (default: 5 minutes)
SYNC_INTERVAL_MS=300000

# ── Code Signing (optional, for distribution) ──────────────────────────
# Windows Authenticode signing
# CSC_LINK="/path/to/certificate.pfx"
# CSC_KEY_PASSWORD="your-pfx-password"

# macOS notarization (requires Apple Developer account)
# APPLE_ID="your-apple-id@example.com"
# APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="your-team-id"

# ── Crash Reporting (optional) ────────────────────────────────────────
# CRASH_REPORTER_URL="https://your-crash-endpoint.example.com/crash-reports"
