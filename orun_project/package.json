{
  "name": "orun-os",
  "productName": "Orun OS",
  "description": "Orun OS — a personal AI desktop assistant with local and cloud model support.",
  "author": "Grupo Orun Soluções Tecnológicas",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:rebuild": "electron-builder install-app-deps",
    "electron:dev": "npm run electron:rebuild && concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:start": "npm run electron:rebuild && electron .",
    "dist": "npm run electron:rebuild && vite build && electron-builder",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fal-ai/client": "^1.10.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@remotion/bundler": "^4.0.489",
    "@remotion/renderer": "^4.0.489",
    "@supabase/supabase-js": "^2.110.2",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "better-sqlite3": "11.10.0",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "dotenv": "^17.4.2",
    "electron-log": "5.2.4",
    "electron-updater": "6.3.9",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "node-audio-mixer": "^2.2.0",
    "node-cron": "3.0.3",
    "node-wav": "^0.0.2",
    "pg": "^8.22.0",
    "qrcode": "1.5.4",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "remotion": "^4.0.489",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "9.1.0",
    "cross-env": "7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "24.13.3",
    "png-to-ico": "^3.0.2",
    "tailwindcss": "4.1.12",
    "vite": "6.3.5",
    "vitest": "2.1.8",
    "wait-on": "8.0.1"
  },
  "build": {
    "appId": "com.grupoorun.orunos",
    "productName": "Orun OS",
    "artifactName": "Orun-OS-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon-top.ico",
      "uninstallerIcon": "build/icon-top.ico",
      "installerHeaderIcon": "build/icon-top.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Orun OS"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "caiqueDeOliveira-dev",
      "repo": "OrunOS"
    }
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
